# Copy this file to .env.local and fill in the values from Supabase + Google Cloud Console.

# === Supabase ===
# Found in : Supabase Dashboard > Settings > API Keys
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...

# Server-only (NEVER commit to git, do not expose in browser)
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_DB_PASSWORD=your-db-password

# === Google OAuth ===
# Found in : Google Cloud Console > APIs & Services > Credentials > OAuth 2.0 Client
# Authorized redirect URIs must include: https://<your-project-ref>.supabase.co/auth/v1/callback
# Authorized JS origins must include: http://localhost:5173 + your prod domain
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# === Stripe (later) ===
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
