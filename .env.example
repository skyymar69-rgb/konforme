# Copiez ce fichier vers .env.local et remplissez les valeurs.

# === Appwrite (backend open source — cloud.appwrite.io, région Francfort) ===
# Console Appwrite > votre projet > Settings
VITE_APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
VITE_APPWRITE_PROJECT_ID=

# Clé API server-only (NE JAMAIS l'exposer au navigateur ni la committer).
# Console > Overview > Integrations > API keys — scopes requis :
# databases (read/write), tables (read/write), rows (read/write),
# functions (read/write), teams (read)
APPWRITE_API_KEY=

# === Google OAuth (OPTIONNEL — la connexion email/mot de passe fonctionne sans) ===
# Console Google Cloud > APIs & Services > Credentials > OAuth 2.0 Client
# URI de redirection autorisé (fourni par la console Appwrite, provider Google) :
#   https://fra.cloud.appwrite.io/v1/account/sessions/oauth2/callback/google/<PROJECT_ID>
# À coller dans la console Appwrite : Auth > Settings > Google
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# === Assistant IA (OPTIONNEL) ===
# Cle API Anthropic pour la fonction explain-issue ("Expliquer et corriger").
# Sans cle, la fonctionnalite est simplement masquee dans l'interface.
ANTHROPIC_API_KEY=

# === Stripe (plus tard) ===
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
